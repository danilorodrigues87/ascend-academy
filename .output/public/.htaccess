# SPA fallback — HostGator / Apache compartilhado
# Rotas do React (/login, /dashboard, …) devem cair em index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Se o arquivo ou pasta existir, serve normalmente (assets, brand, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Demais URLs → shell do SPA
  RewriteRule ^ index.html [L]
</IfModule>

# Evita listagem de diretório (403 sem index era comum sem este arquivo)
Options -Indexes

DirectoryIndex index.html
